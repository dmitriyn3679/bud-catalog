{
  "name": "catalog-shop",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "client",
    "admin"
  ],
  "scripts": {
    "build": "npm run build --workspace=backend",
    "start": "npm run start --workspace=backend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:client": "npm run dev --workspace=client",
    "dev:admin": "npm run dev --workspace=admin",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:client\" \"npm run dev:admin\"",
    "build:client": "npm run build --workspace=client",
    "build:admin": "npm run build --workspace=admin",
    "test": "vitest run --config backend/vitest.config.ts",
    "test:watch": "vitest --config backend/vitest.config.ts",
    "test:coverage": "vitest run --config backend/vitest.config.ts --coverage"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
